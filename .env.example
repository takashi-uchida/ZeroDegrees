# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Chat Models
OPENAI_CHAT_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Database
# Local example: Unix socket for a local Postgres server on port 5433
DATABASE_URL=postgresql+asyncpg://zerodegrees@/zerodegrees?host=/tmp/zerodegrees-pg-socket&port=5433

# Environment
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Forum Configuration
FORUM_ROUNDS=2
MAX_CANDIDATES=10
